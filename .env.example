# Backend Configuration
DEBUG=false
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Database - MongoDB
MONGO_DB_NAME=freelancer
MONGO_HOST=mongodb://root:rootpassword@mongodb:27017/
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=rootpassword

# Chat Protection Service
CHAT_PROTECTION_ENABLED=true
CHAT_PROTECTION_SERVICE_URL=http://protection:8001

# Face Verification Service
FACE_VERIFICATION_SERVICE_URL=http://face-verification:8001
FACE_VERIFICATION_PUBLIC_URL=http://localhost:8002

# File Uploads
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
UPLOAD_FOLDER=uploads/

# Cloudinary (for media storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# JWT Authentication
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://yourdomain.com

# Email Configuration (for notifications)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_PROTECTION_URL=http://localhost:8001
NEXT_PUBLIC_FACE_VERIFICATION_URL=http://localhost:8002

# Protection Service Configuration
TESSERACT_PATH=/usr/bin/tesseract  # Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
OCR_RESIZE_SCALE=2.0
OCR_ENABLE_ENHANCEMENT=true
OCR_GAUSSIAN_KERNEL=5

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json  # or "text" for human-readable

# Redis (for caching/sessions - optional)
REDIS_URL=redis://localhost:6379/0

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600  # seconds

# Sentry (for error tracking - optional)
SENTRY_DSN=

# Environment
ENVIRONMENT=development  # development, staging, production
